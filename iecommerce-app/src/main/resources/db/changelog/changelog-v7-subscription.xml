<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="24-subscription-plan-table" author="chamrong">
        <createTable tableName="subscription_plan">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="code" type="VARCHAR(50)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="TEXT"/>
            <column name="price_amount" type="DECIMAL(19,4)"/>
            <column name="price_currency" type="VARCHAR(3)"/>
            <column name="max_products" type="INTEGER"/>
            <column name="max_variants" type="INTEGER" defaultValueNumeric="0"/>
            <column name="max_orders_per_month" type="INTEGER"/>
            <column name="max_staff_profiles" type="INTEGER"/>
            <column name="custom_domain_allowed" type="BOOLEAN" defaultValueBoolean="false"/>
            <column name="active" type="BOOLEAN" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="false"/>
            </column>
            <column name="deleted" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="deleted_at" type="TIMESTAMP WITH TIME ZONE"/>
        </createTable>

        <insert tableName="subscription_plan">
            <column name="code" value="FREE"/>
            <column name="name" value="Free Startup"/>
            <column name="price_amount" valueNumeric="0.00"/>
            <column name="price_currency" value="USD"/>
            <column name="max_products" valueNumeric="50"/>
            <column name="max_variants" valueNumeric="200"/>
            <column name="max_orders_per_month" valueNumeric="100"/>
            <column name="max_staff_profiles" valueNumeric="2"/>
            <column name="created_at" valueDate="now()"/>
            <column name="updated_at" valueDate="now()"/>
            <column name="deleted" valueBoolean="false"/>
        </insert>
        
        <insert tableName="subscription_plan">
            <column name="code" value="PRO"/>
            <column name="name" value="Professional Merchant"/>
            <column name="price_amount" valueNumeric="49.00"/>
            <column name="price_currency" value="USD"/>
            <column name="max_products" valueNumeric="1000"/>
            <column name="max_variants" valueNumeric="5000"/>
            <column name="max_orders_per_month" valueNumeric="5000"/>
            <column name="max_staff_profiles" valueNumeric="10"/>
            <column name="custom_domain_allowed" valueBoolean="true"/>
            <column name="created_at" valueDate="now()"/>
            <column name="updated_at" valueDate="now()"/>
            <column name="deleted" valueBoolean="false"/>
        </insert>
    </changeSet>

    <changeSet id="25-tenant-subscription-table" author="chamrong">
        <createTable tableName="tenant_subscription">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="tenant_id" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="plan_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_tenant_sub_plan" referencedTableName="subscription_plan" referencedColumnNames="id"/>
            </column>
            <column name="status" type="VARCHAR(30)">
                <constraints nullable="false"/>
            </column>
            <column name="start_date" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="false"/>
            </column>
            <column name="end_date" type="TIMESTAMP WITH TIME ZONE"/>
            <column name="last_billing_date" type="TIMESTAMP WITH TIME ZONE"/>
            <column name="next_billing_date" type="TIMESTAMP WITH TIME ZONE"/>
            <column name="auto_renew" type="BOOLEAN" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="false"/>
            </column>
            <column name="deleted" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="deleted_at" type="TIMESTAMP WITH TIME ZONE"/>
        </createTable>
    </changeSet>

</databaseChangeLog>
