<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!-- ================================================================
         CATALOG MODULE — V2 Schema
         Strategy:
           - catalog_products: partitioned LIST(deleted) → RANGE(created_at/year)
           - catalog_product_translations: simple table, indexed (product_id, locale)
           - catalog_categories: adjacency list + materialized path, GIN index
           - All _translation tables: UNIQUE(entity_id, locale)
           - Partial indexes: only WHERE deleted = FALSE for hot reads
           - GIN index: full-text search on product name + description
         ================================================================ -->

    <!-- 22: Drop old stub catalog tables before recreating them properly -->
    <changeSet id="22-drop-old-catalog-stub" author="chamrong">
        <sql splitStatements="false">
            DROP TABLE IF EXISTS catalog_product_variant CASCADE;
            DROP TABLE IF EXISTS catalog_product CASCADE;
        </sql>
    </changeSet>

    <!-- 23: catalog_categories (must exist before products FK) -->
    <changeSet id="23-catalog-categories" author="chamrong">
        <sql splitStatements="false">
            CREATE TABLE catalog_categories (
                id                BIGSERIAL,
                tenant_id         VARCHAR(100)  NOT NULL,
                slug              VARCHAR(255)  NOT NULL,
                parent_id         BIGINT        REFERENCES catalog_categories(id) ON DELETE SET NULL,
                materialized_path VARCHAR(1000),          -- e.g. /1/4/12/
                depth             INTEGER       NOT NULL DEFAULT 0,
                sort_order        INTEGER       NOT NULL DEFAULT 0,
                image_url         VARCHAR(500),
                is_active         BOOLEAN       NOT NULL DEFAULT TRUE,
                created_at        TIMESTAMPTZ   NOT NULL DEFAULT NOW(),
                updated_at        TIMESTAMPTZ   NOT NULL DEFAULT NOW(),
                deleted           BOOLEAN       NOT NULL DEFAULT FALSE,
                deleted_at        TIMESTAMPTZ,
                PRIMARY KEY (id),
                UNIQUE (tenant_id, slug)
            );

            -- Fast subtree queries: WHERE materialized_path LIKE '/1/4/%'
            CREATE INDEX idx_category_path    ON catalog_categories(tenant_id, materialized_path)
                WHERE deleted = FALSE;
            CREATE INDEX idx_category_parent  ON catalog_categories(parent_id)
                WHERE deleted = FALSE;
            CREATE INDEX idx_category_active  ON catalog_categories(tenant_id, is_active)
                WHERE deleted = FALSE;
        </sql>
    </changeSet>

    <!-- 24: catalog_products — partitioned by deleted status (LIST) then year (RANGE) -->
    <changeSet id="24-catalog-products-partitioned" author="chamrong">
        <sql splitStatements="false">
            CREATE TABLE catalog_products (
                id                      BIGSERIAL,
                tenant_id               VARCHAR(100)  NOT NULL,
                slug                    VARCHAR(255)  NOT NULL,
                status                  VARCHAR(20)   NOT NULL DEFAULT 'DRAFT',
                product_type            VARCHAR(20)   NOT NULL DEFAULT 'PHYSICAL',
                category_id             BIGINT        REFERENCES catalog_categories(id) ON DELETE SET NULL,
                base_price_amount       NUMERIC(19,4),
                base_price_currency     VARCHAR(3),
                compare_at_price_amount NUMERIC(19,4),
                compare_at_price_currency VARCHAR(3),
                tax_category            VARCHAR(50)   DEFAULT 'STANDARD',
                tags                    TEXT,
                created_at              TIMESTAMPTZ   NOT NULL DEFAULT NOW(),
                updated_at              TIMESTAMPTZ   NOT NULL DEFAULT NOW(),
                deleted                 BOOLEAN       NOT NULL DEFAULT FALSE,
                deleted_at              TIMESTAMPTZ,
                PRIMARY KEY (id, deleted, created_at),
                UNIQUE (tenant_id, slug)
            ) PARTITION BY LIST (deleted);

            -- L1 partitions: active vs soft-deleted
            CREATE TABLE catalog_products_active   PARTITION OF catalog_products
                FOR VALUES IN (FALSE)
                PARTITION BY RANGE (created_at);

            CREATE TABLE catalog_products_deleted  PARTITION OF catalog_products
                FOR VALUES IN (TRUE)
                PARTITION BY RANGE (created_at);

            -- L2 year partitions 2024–2124 (uses helper function from v1 migration)
            SELECT create_year_partitions('catalog_products_active',  'catalog_products_active',  2024, 2124);
            SELECT create_year_partitions('catalog_products_deleted', 'catalog_products_deleted', 2024, 2124);
        </sql>
    </changeSet>

    <!-- 25: catalog_products indexes -->
    <changeSet id="25-catalog-products-indexes" author="chamrong">
        <sql splitStatements="false">
            -- Hot admin list: filter by tenant + status
            CREATE INDEX idx_products_tenant_status
                ON catalog_products(tenant_id, status)
                WHERE deleted = FALSE;

            -- Storefront slug lookup
            CREATE INDEX idx_products_slug
                ON catalog_products(tenant_id, slug)
                WHERE deleted = FALSE;

            -- Category drill-down queries
            CREATE INDEX idx_products_category
                ON catalog_products(category_id)
                WHERE deleted = FALSE;

            -- Tenant-level price browsing (range queries on price)
            CREATE INDEX idx_products_price
                ON catalog_products(tenant_id, base_price_amount)
                WHERE deleted = FALSE AND status = 'ACTIVE';
        </sql>
    </changeSet>

    <!-- 26: catalog_product_translations -->
    <changeSet id="26-catalog-product-translations" author="chamrong">
        <createTable tableName="catalog_product_translations">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="product_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="locale" type="VARCHAR(10)">
                <constraints nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="TEXT"/>
            <column name="short_description" type="VARCHAR(512)"/>
            <column name="meta_title" type="VARCHAR(255)"/>
            <column name="meta_description" type="VARCHAR(512)"/>
        </createTable>
        <addForeignKeyConstraint
            baseTableName="catalog_product_translations"
            baseColumnNames="product_id"
            referencedTableName="catalog_products"
            referencedColumnNames="id"
            constraintName="fk_product_translation_product"
            onDelete="CASCADE"/>
        <addUniqueConstraint
            tableName="catalog_product_translations"
            columnNames="product_id, locale"
            constraintName="uq_product_translation_locale"/>
        <sql>
            CREATE INDEX idx_product_trans_locale
                ON catalog_product_translations(product_id, locale);
            <!-- GIN full-text search across translated name + description -->
            CREATE INDEX idx_product_trans_fts
                ON catalog_product_translations
                USING GIN (to_tsvector('simple', name || ' ' || COALESCE(description, '')));
        </sql>
    </changeSet>

