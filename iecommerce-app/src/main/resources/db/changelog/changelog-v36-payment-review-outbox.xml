<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!--
        v36 — Payment & Review Outbox Tables
        ====================================
        Creates the missing `payment_outbox_event` and `review_outbox_event` tables
        used by the transactional outbox schedulers in the payment and review modules.

        Schemas are aligned with other outbox tables (order_outbox_event, promotion_outbox_event).
    -->

    <changeSet id="v36-01-payment-outbox-event" author="assistant">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="payment_outbox_event"/>
            </not>
        </preConditions>

        <createTable tableName="payment_outbox_event">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="tenant_id" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="event_type" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="payload" type="TEXT">
                <constraints nullable="false"/>
            </column>
            <!-- PENDING | SENT | FAILED -->
            <column name="status" type="VARCHAR(20)" defaultValue="PENDING">
                <constraints nullable="false"/>
            </column>
            <column name="retry_count" type="INTEGER" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="false"/>
            </column>
            <column name="processed_at" type="TIMESTAMP WITH TIME ZONE"/>
        </createTable>

        <createIndex tableName="payment_outbox_event" indexName="idx_payment_outbox_status_created">
            <column name="status"/>
            <column name="created_at"/>
        </createIndex>
    </changeSet>

    <changeSet id="v36-02-review-outbox-event" author="assistant">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="review_outbox_event"/>
            </not>
        </preConditions>

        <createTable tableName="review_outbox_event">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="tenant_id" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="event_type" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="payload" type="TEXT">
                <constraints nullable="false"/>
            </column>
            <!-- PENDING | SENT | FAILED -->
            <column name="status" type="VARCHAR(20)" defaultValue="PENDING">
                <constraints nullable="false"/>
            </column>
            <column name="retry_count" type="INTEGER" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="false"/>
            </column>
            <column name="processed_at" type="TIMESTAMP WITH TIME ZONE"/>
        </createTable>

        <createIndex tableName="review_outbox_event" indexName="idx_review_outbox_status_created">
            <column name="status"/>
            <column name="created_at"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>

