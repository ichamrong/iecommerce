<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="v19-promotion-hardening-schema" author="antigravity">
        <!-- 1. Refactor existing Promotion table -->
        <addColumn tableName="promotion">
            <column name="status" type="VARCHAR(20)" defaultValue="DRAFT">
                <constraints nullable="false"/>
            </column>
            <column name="priority" type="INTEGER" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="is_stackable" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="usage_limit" type="INTEGER"/>
            <column name="used_count" type="INTEGER" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="version" type="BIGINT" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
        </addColumn>

        <!-- 2. Create PromotionRule table (Relational replacement for ruleData) -->
        <createTable tableName="promotion_rule">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="tenant_id" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="promotion_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_rule_promotion" referencedTableName="promotion" referencedColumnNames="id"/>
            </column>
            <column name="type" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="rule_data" type="TEXT">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="false"/>
            </column>
            <column name="deleted" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="deleted_at" type="TIMESTAMP WITH TIME ZONE"/>
        </createTable>

        <!-- 3. Create PromotionRedemption table for Transaction Safety -->
        <createTable tableName="promotion_redemption">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="tenant_id" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="promotion_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_redemption_promotion" referencedTableName="promotion" referencedColumnNames="id"/>
            </column>
            <column name="order_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="customer_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="redemption_key" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="amount" type="DECIMAL(19,4)">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="false"/>
            </column>
            <column name="deleted" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="deleted_at" type="TIMESTAMP WITH TIME ZONE"/>
        </createTable>

        <!-- 4. Idempotency Constraint -->
        <addUniqueConstraint tableName="promotion_redemption" columnNames="tenant_id, redemption_key" constraintName="uk_promotion_redemption_key"/>

        <!-- 5. Performance Indexes -->
        <createIndex tableName="promotion" indexName="idx_promotion_tenant_status">
            <column name="tenant_id"/>
            <column name="status"/>
        </createIndex>
        <createIndex tableName="promotion" indexName="idx_promotion_code">
            <column name="tenant_id"/>
            <column name="code"/>
        </createIndex>

        <!-- 6. Outbox Table for Reliable Messaging -->
        <createTable tableName="promotion_outbox_event">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="tenant_id" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="event_type" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="payload" type="TEXT">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="aggregate_id" type="BIGINT"/>
            <column name="retry_count" type="INTEGER" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="false"/>
            </column>
            <column name="processed_at" type="TIMESTAMP WITH TIME ZONE"/>
            <column name="next_attempt_at" type="TIMESTAMP WITH TIME ZONE"/>
            <column name="trace_id" type="VARCHAR(64)"/>
        </createTable>

        <createIndex tableName="promotion_outbox_event" indexName="idx_promotion_outbox_status_retry">
            <column name="status"/>
            <column name="retry_count"/>
            <column name="next_attempt_at"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
