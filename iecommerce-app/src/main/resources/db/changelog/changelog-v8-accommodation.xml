<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="24-catalog-capacity" author="chamrong">
        <addColumn tableName="catalog_product_variants">
            <column name="capacity" type="INTEGER" defaultValueNumeric="1">
                <constraints nullable="false"/>
            </column>
        </addColumn>
    </changeSet>

    <changeSet id="25-booking-stay-limits" author="chamrong">
        <addColumn tableName="booking_availability_rule">
            <column name="min_stay_nights" type="INTEGER"/>
            <column name="max_stay_nights" type="INTEGER"/>
        </addColumn>
    </changeSet>

    <changeSet id="26-booking-availability-staff-link" author="chamrong">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="booking_availability_rule" columnName="staff_id"/>
            </not>
        </preConditions>
        <comment>Link availability rules to staff via staff_id</comment>
        <addColumn tableName="booking_availability_rule">
            <column name="staff_id" type="BIGINT"/>
        </addColumn>
    </changeSet>

    <changeSet id="27-order-timed-items" author="chamrong">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="ecommerce_order_item" columnName="start_at"/>
            </not>
        </preConditions>
        <addColumn tableName="ecommerce_order_item">
            <column name="start_at" type="TIMESTAMP WITH TIME ZONE"/>
            <column name="end_at" type="TIMESTAMP WITH TIME ZONE"/>
        </addColumn>
    </changeSet>

    <changeSet id="28-order-deposit" author="chamrong">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="ecommerce_order" columnName="deposit_amount"/>
            </not>
        </preConditions>
        <addColumn tableName="ecommerce_order">
            <column name="deposit_amount" type="DECIMAL(19,4)"/>
            <column name="deposit_currency" type="VARCHAR(3)"/>
        </addColumn>
    </changeSet>

    <changeSet id="29-catalog-product-images" author="chamrong">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="catalog_product_images"/>
            </not>
        </preConditions>
        <createTable tableName="catalog_product_images">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <!-- No FK to catalog_products(id): parent is partitioned with composite PK; see v2 catalog changelog. -->
            <column name="product_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="asset_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="sort_order" type="INTEGER" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="alt_text" type="VARCHAR(255)"/>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="false"/>
            </column>
            <column name="deleted" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="deleted_at" type="TIMESTAMP WITH TIME ZONE"/>
        </createTable>
    </changeSet>

</databaseChangeLog>
