<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="18-order-asset-tenancy" author="chamrong">
        <addColumn tableName="ecommerce_order">
            <column name="tenant_id" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
        </addColumn>
        <addColumn tableName="ecommerce_asset">
            <column name="tenant_id" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
        </addColumn>
    </changeSet>

    <changeSet id="19-invoice-status" author="chamrong">
        <addColumn tableName="invoice">
            <column name="status" type="VARCHAR(30)" defaultValue="DRAFT">
                <constraints nullable="false"/>
            </column>
        </addColumn>
    </changeSet>

    <changeSet id="20-promotion-fields" author="chamrong">
        <addColumn tableName="promotion">
            <column name="code" type="VARCHAR(50)">
                <constraints unique="true"/>
            </column>
            <column name="active" type="BOOLEAN" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
        </addColumn>
    </changeSet>

    <changeSet id="21-review-notification-updates" author="chamrong">
        <preConditions onFail="MARK_RAN" onError="MARK_RAN">
            <not>
                <columnExists tableName="product_review" columnName="status"/>
            </not>
        </preConditions>
        <addColumn tableName="product_review">
            <column name="status" type="VARCHAR(20)" defaultValue="PENDING">
                <constraints nullable="false"/>
            </column>
        </addColumn>
        <addColumn tableName="notification_log">
            <column name="error_message" type="TEXT"/>
        </addColumn>
    </changeSet>

    <changeSet id="22-payment-updates" author="chamrong">
        <preConditions onFail="MARK_RAN" onError="MARK_RAN">
            <not>
                <columnExists tableName="payment_transaction" columnName="status"/>
            </not>
        </preConditions>
        <addColumn tableName="payment_transaction">
            <column name="status" type="VARCHAR(50)" defaultValue="PENDING">
                <constraints nullable="false"/>
            </column>
            <column name="external_id" type="VARCHAR(255)"/>
        </addColumn>
    </changeSet>

    <changeSet id="23-booking-tables" author="chamrong">
        <createTable tableName="booking">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="tenant_id" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="resource_product_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="resource_variant_id" type="BIGINT"/>
            <column name="assigned_staff_id" type="BIGINT"/>
            <column name="customer_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="start_at" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="false"/>
            </column>
            <column name="end_at" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="false"/>
            </column>
            <column name="type" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="VARCHAR(30)">
                <constraints nullable="false"/>
            </column>
            <column name="total_price_amount" type="DECIMAL(19,4)"/>
            <column name="total_price_currency" type="VARCHAR(3)"/>
            <column name="customer_notes" type="TEXT"/>
            <column name="internal_notes" type="TEXT"/>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="false"/>
            </column>
            <column name="deleted" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="deleted_at" type="TIMESTAMP WITH TIME ZONE"/>
        </createTable>

        <createTable tableName="booking_blocked_slot">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="booking_id" type="BIGINT">
                <constraints foreignKeyName="fk_blocked_slot_booking" referencedTableName="booking" referencedColumnNames="id"/>
            </column>
            <column name="resource_product_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="resource_variant_id" type="BIGINT"/>
            <column name="start_at" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="false"/>
            </column>
            <column name="end_at" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="false"/>
            </column>
            <column name="reason" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="note" type="TEXT"/>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="false"/>
            </column>
            <column name="deleted" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="deleted_at" type="TIMESTAMP WITH TIME ZONE"/>
        </createTable>

        <createTable tableName="booking_availability_rule">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="tenant_id" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="resource_product_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="resource_variant_id" type="BIGINT"/>
            <column name="day_of_week" type="VARCHAR(10)">
                <constraints nullable="false"/>
            </column>
            <column name="open_time" type="TIME">
                <constraints nullable="false"/>
            </column>
            <column name="close_time" type="TIME">
                <constraints nullable="false"/>
            </column>
            <column name="slot_duration_minutes" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="false"/>
            </column>
            <column name="deleted" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="deleted_at" type="TIMESTAMP WITH TIME ZONE"/>
        </createTable>
    </changeSet>

</databaseChangeLog>
