<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="v37-payment-ledger-fix" author="antigravity">
        <comment>Fixing payment_financial_ledger schema to match the domain model</comment>
        
        <addColumn tableName="payment_financial_ledger">
            <column name="notes" type="TEXT"/>
            <column name="manual_override" type="BOOLEAN" defaultValueBoolean="false"/>
            <column name="manual_override_reason" type="VARCHAR(255)"/>
            <column name="approved_by_admin" type="VARCHAR(255)"/>
            <column name="deleted_at" type="TIMESTAMP WITH TIME ZONE"/>
        </addColumn>
    </changeSet>

</databaseChangeLog>
