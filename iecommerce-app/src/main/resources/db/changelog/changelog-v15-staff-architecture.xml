<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="40-staff-architecture-update" author="chamrong">
        <!-- Optional: add version for optimistic locking -->
        <addColumn tableName="staff_profile">
            <column name="version" type="BIGINT" defaultValueNumeric="0"/>
        </addColumn>

        <!-- Indexes for Cursor Pagination and Lookups -->
        <createIndex tableName="staff_profile" indexName="idx_staff_cursor">
            <column name="created_at" descending="true"/>
            <column name="id" descending="true"/>
        </createIndex>

        <createIndex tableName="staff_profile" indexName="idx_staff_status">
            <column name="status"/>
        </createIndex>

        <createIndex tableName="staff_profile" indexName="idx_staff_role">
            <column name="role"/>
        </createIndex>

        <!-- Audit Log Table -->
        <createTable tableName="staff_audit_log">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="actor_id" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="target_staff_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="action_type" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="timestamp" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex tableName="staff_audit_log" indexName="idx_audit_staff">
            <column name="target_staff_id"/>
        </createIndex>

        <createIndex tableName="staff_audit_log" indexName="idx_audit_actor">
            <column name="actor_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
