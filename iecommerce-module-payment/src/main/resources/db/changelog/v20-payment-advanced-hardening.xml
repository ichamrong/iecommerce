<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.31.xsd">

    <changeSet id="v20-payment-advanced-hardening" author="antigravity">
        <!-- 1. Transaction Log Table -->
        <createTable tableName="payment_transaction">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="payment_intent_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="provider_event_id" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="type" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="amount" type="DECIMAL(19, 4)">
                <constraints nullable="false"/>
            </column>
            <column name="currency" type="VARCHAR(3)">
                <constraints nullable="false"/>
            </column>
            <column name="raw_status" type="VARCHAR(100)"/>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addUniqueConstraint tableName="payment_transaction" 
                             columnNames="payment_intent_id, provider_event_id" 
                             constraintName="uk_payment_tx_dedup"/>

        <addForeignKeyConstraint baseTableName="payment_transaction" baseColumnNames="payment_intent_id"
                                 referencedTableName="payment_intent" referencedColumnNames="id"
                                 constraintName="fk_payment_tx_intent"/>

        <!-- 2. Outbox Table -->
        <createTable tableName="payment_outbox_event">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="tenant_id" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="event_type" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="payload" type="TEXT">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="retry_count" type="INT" defaultValue="0">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="false"/>
            </column>
            <column name="processed_at" type="TIMESTAMP WITH TIME ZONE"/>
        </createTable>

        <createIndex tableName="payment_outbox_event" indexName="idx_payment_outbox_status_created">
            <column name="status"/>
            <column name="created_at"/>
        </createIndex>

        <!-- 3. Webhook Dedup Fallback -->
        <addColumn tableName="payment_webhook_event">
            <column name="payload_hash" type="VARCHAR(64)"/>
        </addColumn>
        
        <createIndex tableName="payment_webhook_event" indexName="idx_webhook_payload_hash">
            <column name="payload_hash"/>
        </createIndex>

        <addUniqueConstraint tableName="payment_webhook_event"
                             columnNames="provider, payload_hash"
                             constraintName="uk_webhook_payload_hash"/>

        <!-- 4. Optimization for Keyset Pagination -->
        <createIndex tableName="payment_ledger" indexName="idx_payment_ledger_pagination">
            <column name="tenant_id"/>
            <column name="created_at"/>
            <column name="id"/>
        </createIndex>

    </changeSet>

    <changeSet id="20240320-payment-intent-qr-deep" author="chamrong">
        <addColumn tableName="payment_intent">
            <column name="qr_code" type="TEXT"/>
            <column name="deep_link" type="TEXT"/>
        </addColumn>
    </changeSet>

</databaseChangeLog>
